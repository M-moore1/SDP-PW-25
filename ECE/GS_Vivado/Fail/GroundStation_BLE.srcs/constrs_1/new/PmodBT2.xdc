#ZCU102 PMOD BT2 J55 Connections

set_property PACKAGE_PIN A20      [get_ports "BT2_RTS"] ;
set_property IOSTANDARD  LVCMOS33 [get_ports "BT2_RTS"] ;

set_property PACKAGE_PIN B20      [get_ports "BT2_RX"] ;
set_property IOSTANDARD  LVCMOS33 [get_ports "BT2_RX"] ; 

set_property PACKAGE_PIN A22      [get_ports "BT2_TX"] ; 
set_property IOSTANDARD  LVCMOS33 [get_ports "BT2_TX"] ; 

set_property PACKAGE_PIN A21      [get_ports "BT2_CTS"] ;
set_property IOSTANDARD  LVCMOS33 [get_ports "BT2_CTS"] ;

set_property PACKAGE_PIN B21      [get_ports "BT2_STATUS"] ;
set_property IOSTANDARD  LVCMOS33 [get_ports "BT2_STATUS"] ;

set_property PACKAGE_PIN C21      [get_ports "BT2_RST"] ;
set_property IOSTANDARD  LVCMOS33 [get_ports "BT2_RST"] ;

